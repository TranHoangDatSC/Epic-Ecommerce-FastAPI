{
  "name": "oldshop-ecommerce",
  "version": "1.0.0",
  "scripts": {
    "start:backend": "cd backend && venv\\Scripts\\activate && python -m app.main",
    "start:frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "install:all": "cd frontend && npm install",
    "backend": "cd backend && python -m app.main"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "sweetalert2": "^11.26.24"
  }
}
