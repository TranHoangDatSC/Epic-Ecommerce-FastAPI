# =========================================
# OldShop E-commerce Platform - Environment Variables
# =========================================

# [DATABASE]
# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:123@localhost:5432/oldshop
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123
DB_NAME=oldshop

# [BACKEND_AUTH]
# JWT Authentication Settings
SECRET_KEY=your-secret-key-change-this-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# [BACKEND_SERVER]
# Server Configuration
DEBUG=True
LOG_LEVEL=INFO
API_V1_STR=/api/v1
PROJECT_NAME=OldShop API
PROJECT_VERSION=1.0.0

# [FRONTEND_API]
# Frontend API Configuration (for production builds)
# Development: http://localhost:8000/api/v1
# Production: https://api.oldshop.com/api/v1